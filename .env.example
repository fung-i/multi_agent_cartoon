# 留空则自动回退到内置 mock LLM，demo 仍可端到端运行。
#
# 通用配置（推荐）：只要是 OpenAI 兼容接口都可以这样配。
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=

# —— 常见厂家示例（任选其一，把前面的 # 去掉即可）——

# OpenAI（默认，无需 LLM_BASE_URL）
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o-mini

# DeepSeek
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-756b4de1e6d64e71be9b4bf6468b9728
LLM_MODEL=deepseek-chat

# 阿里 Qwen（百炼，OpenAI 兼容模式）
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-xxx
# LLM_MODEL=qwen-plus

# 豆包（火山方舟，OpenAI 兼容）
# LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# LLM_API_KEY=xxx
# LLM_MODEL=doubao-pro-32k   # 或你在方舟创建的 endpoint id

# 月之暗面 Kimi
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_API_KEY=sk-xxx
# LLM_MODEL=moonshot-v1-8k

# 智谱 GLM
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_API_KEY=xxx
# LLM_MODEL=glm-4-flash

# Gemini（通过 OpenAI 兼容端点）
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=xxx
# LLM_MODEL=gemini-2.0-flash

# 聚合网关
# OpenRouter:  LLM_BASE_URL=https://openrouter.ai/api/v1
# SiliconFlow: LLM_BASE_URL=https://api.siliconflow.cn/v1
